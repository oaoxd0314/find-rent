# ── 範本 ──────────────────────────────────────────────────
# 複製本檔成 config/fb-targets.yml 再填自己的設定:
#   cp config/fb-targets.yml.sample config/fb-targets.yml
# fb-scan.mjs 只讀 config/fb-targets.yml(本範本不會被讀)。

# ── 1. TARGET:要爬哪些 FB 社團 ──────────────────────────
groups:
  - name: "社團顯示名稱"
    url: "https://www.facebook.com/groups/XXXXXXXXXXXX/"
    enabled: true
    scroll: 20          # 往下滾幾次(抓多少貼文,越大越多越慢)
    sort: "new"

  # - name: "第二個社團"
  #   url: "https://www.facebook.com/groups/YYYYYYYYYYYY/"
  #   enabled: true
  #   scroll: 20

# ── 2. 條件 list ─────────────────────────────────────────
# 每篇貼文分別比對每組,取最佳結果。判定 = GATE(門檻)+ SCORE(評分排序):
#   GATE(保守,只在明確不合時丟):買賣/求租文、exclude 命中、租金整段超出範圍
#   SCORE:每命中一欄 → include 計 2 分、optional 計 1 分
#   分層:include 全中 → ✅ 符合;否則 score≥1 → 〽️ 待確認(按分排序);零命中 → 不顯示
#
# 三個 block 共用欄位(每個都可省略):
#   layout: []           格局,符合任一即命中(房型用房間數比對,1房1廳/2房1廳都認)
#   locations: []        地點,出現任一即命中
#   keywords: []         關鍵字,出現任一即命中
#   must_have: []        設備,須全部出現才算命中
#   rent_min / rent_max  (只放 include)租金落在 [min,max];整段超出 → 丟,沒寫 → 放行
#   roommate_female: true (放 optional)偵測到男 → 🚻 性別待確認;女生友善訊號 → 加分
#
# 註:買賣文(出售/賞屋/1598萬…)與求租文(求租/求獨立套房/想找雅房…)
#     fb-scan.mjs 已內建語意偵測自動擋掉,不必逐字列在 keywords。
searches:

  - name: "條件1:整層住家"
    include:                        # 全中 → ✅ 符合
      rent_min: 10000
      rent_max: 33000
      layout:
        - "兩房一廳"
      locations:
        - "信義"
        - "大安"
    optional:                       # 加分:沒全中也能進 〽️、命中越多排越前
      layout:
        - "一房一廳"
      keywords:
        - "陽台"
        - "洗衣機"
        - "冰箱"
    exclude:                        # 任一命中就丟掉
      keywords:
        - "頂加"
        - "頂樓加蓋"
        - "地下室"
        - "委託價"
      locations:
        - "三重"
        - "蘆洲"

  - name: "條件2:女生友善"
    include:
      rent_min: 10000
      rent_max: 18000
      layout:
        - "套房"
        - "雅房"
      locations:
        - "信義"
        - "大安"
    optional:
      roommate_female: true         # 偵測到男 → 🚻 性別待確認;女生友善訊號 → 加分
    exclude:
      keywords:
        - "頂加"
        - "頂樓加蓋"
        - "地下室"
        - "委託價"
      locations:
        - "三重"
        - "蘆洲"

# ── 3. 去重(看過的貼文記這裡,不重複撈) ────────────────
dedup_file: "data/fb-seen.tsv"

# ── 4. 結果寫到哪 ─────────────────────────────────────────
# 相對路徑 → 存在本專案 output/(已 gitignore)。也可填絕對路徑或 ~/...
# 每天:scan-YYYY-MM-DD.jsonl(資料層) / find-YYYY-MM-DD.md(命中清單)
output_dir: "output"
